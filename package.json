{
  "name": "service-template-project",
  "version": "0.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/a-novel/service-template.git"
  },
  "license": "AGPL-3.0",
  "type": "module",
  "workspaces": [
    "."
  ],
  "scripts": {
    "build": "pnpm build:rest && pnpm types:rest && pnpm types:rest-test",
    "build:rest": "rm -rf ./pkg/js/rest/dist && vite build --outDir ./pkg/js/rest/dist -c pkg/js/rest/vite.config.ts",
    "format": "pnpm run format:prettier",
    "format:prettier": "prettier --write . --config prettier.config.ts",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "pnpm build && pnpm i --ignore-scripts",
    "lint": "pnpm lint:stylecheck && pnpm lint:typecheck && pnpm lint:eslint && pnpm run lint:openapi",
    "lint:eslint": "eslint .",
    "lint:openapi": "pnpm redocly lint openapi.yaml",
    "lint:stylecheck": "prettier --check . --config prettier.config.ts",
    "lint:typecheck": "pnpm lint:typecheck:base && pnpm lint:typecheck:rest && pnpm lint:typecheck:test:rest",
    "lint:typecheck:base": "tsc --noEmit",
    "lint:typecheck:rest": "pnpm tsc --p ./pkg/js/rest/tsconfig.json --noEmit",
    "lint:typecheck:test:rest": "pnpm tsc --p ./pkg/js/test/rest/tsconfig.json --noEmit",
    "prepublish:doc": "pnpm prepublish:doc:readme && pnpm prepublish:doc:openapi",
    "prepublish:doc:openapi": "bash scripts/prepublish-version.sh 'version: ' openapi.yaml",
    "prepublish:doc:readme": "bash scripts/prepublish-version.sh 'a-novel/service-template/[^/]+' README.md",
    "publish:major": "bash scripts/publish.sh major",
    "publish:minor": "bash scripts/publish.sh minor",
    "publish:patch": "bash scripts/publish.sh patch",
    "test": "vitest run -c vitest.config.ts",
    "types:rest": "tsc --build pkg/js/rest/tsconfig.build.json",
    "types:rest-test": "tsc --p ./pkg/js/test/rest/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@a-novel-kit/nodelib-browser": "^1.3.18",
    "@a-novel-kit/nodelib-config": "^1.3.18",
    "@a-novel-kit/nodelib-test": "^1.3.18",
    "@eslint/js": "^10.0.1",
    "@redocly/cli": "^2.20.4",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-storybook": "^10.2.8",
    "eslint-plugin-svelte": "^3.15.0",
    "get-port-please": "^3.2.0",
    "globals": "^17.0.0",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.1",
    "jsdom": "^28.0.0",
    "prettier": "^3.6.2",
    "prettier-plugin-packagejson": "^3.0.0",
    "prettier-plugin-sql": "^0.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.0",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=23.11.0",
    "npm": ">=10.9.2"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  }
}
